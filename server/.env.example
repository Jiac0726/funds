PORT=8080
REQUEST_TIMEOUT_MS=10000
ALLOW_ORIGIN=*
CACHE_DISABLED=0
MAX_UPLOAD_BYTES=8388608

# 截图识别引擎：
# - chat-json：OpenAI-compatible 视觉模型直接返回结构化 JSON
# - unlimited-ocr：百度 Unlimited-OCR 先做 OCR，后端再解析支付宝持仓
VISION_PROVIDER=chat-json

# chat-json 示例：
# VISION_API_URL=https://api.example.com/v1/chat/completions
# VISION_API_KEY=你的密钥
# VISION_MODEL=视觉模型名称

# Unlimited-OCR 示例：
# VISION_PROVIDER=unlimited-ocr
# VISION_API_URL=http://127.0.0.1:8000/v1/chat/completions
# VISION_MODEL=baidu/Unlimited-OCR
# VISION_API_KEY=
VISION_API_URL=
VISION_API_KEY=
VISION_MODEL=

# Unlimited-OCR 细项，通常不用改。
UNLIMITED_OCR_SERVER=vllm
UNLIMITED_OCR_MAX_TOKENS=8192
UNLIMITED_OCR_NGRAM_SIZE=35
UNLIMITED_OCR_WINDOW_SIZE=128
UNLIMITED_OCR_IMAGE_MODE=gundam
UNLIMITED_OCR_CUSTOM_LOGIT_PROCESSOR=
# 可选独立基金净值源：Tushare。未配置时小程序会将该源标记为不可用。
TUSHARE_API_URL=https://api.tushare.pro
TUSHARE_TOKEN=
# 微信小程序登录。AppSecret 和令牌密钥只能保存在服务器。
WX_APPID=
WX_APP_SECRET=
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_SECONDS=2592000

# 腾讯云 COS 用户数据备份。Bucket 格式示例：funds-user-1250000000
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_PREFIX=funds-mini/users
