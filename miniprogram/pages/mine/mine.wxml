<view class="page">
  <view class="profile card">
    <view class="avatar">{{loggedIn ? '微' : '基'}}</view>
    <view class="profile-copy">
      <view class="title">基基棒</view>
      <view class="sub">{{authStatusText}}</view>
      <view class="version">小程序端 v{{version}}</view>
    </view>
    <button wx:if="{{!cloudAvailable}}" class="wechat-button" bindtap="loginWechat" disabled="{{true}}">本地模式</button>
    <button wx:else class="logout-button" bindtap="loginWechat">已连接</button>
  </view>

  <view class="stats card">
    <view>
      <text class="label">当前自选</text>
      <text class="count">{{holdingCount}}</text>
    </view>
    <button class="primary-button" bindtap="goEdit">管理自选</button>
  </view>

  <view class="section-title">配置</view>
  <view class="menu card">
    <picker class="source-picker" range="{{dataSources}}" range-key="displayLabel" value="{{sourceIndex}}" bindchange="onDataSourceChange">
      <view class="menu-item">
        <text>基金数据源</text>
        <text class="menu-value">{{currentSourceLabel}} ›</text>
      </view>
    </picker>
    <view wx:if="{{cloudAvailable}}" class="menu-item" bindtap="backupCloud">
      <text>备份到腾讯云</text>
      <text class="menu-value">{{cloudLoading ? '处理中' : '上传当前数据'}}</text>
    </view>
    <view wx:if="{{cloudAvailable}}" class="menu-item" bindtap="restoreCloud">
      <text>从腾讯云恢复</text>
      <text class="menu-value">覆盖本地数据</text>
    </view>
    <view class="menu-item" bindtap="exportConfig">
      <text>导出配置</text>
      <text class="menu-value">复制到剪贴板</text>
    </view>
    <view class="menu-item" bindtap="importConfig">
      <text>导入配置</text>
      <text class="menu-value">从剪贴板读取</text>
    </view>
    <view class="menu-item" bindtap="goImport">
      <text>支付宝截图导入</text>
      <text class="menu-value">AI识别持仓</text>
    </view>
    <view class="menu-item" bindtap="openLegal" data-type="privacy">
      <text>隐私政策</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="openLegal" data-type="risk">
      <text>风险提示与数据说明</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item danger" bindtap="resetConfig">
      <text>恢复默认配置</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section-title">关于</view>
  <view class="menu card">
    <view class="menu-item" bindtap="goHome">
      <text>返回首页</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="openLegal" data-type="agreement">
      <text>用户协议</text>
      <text class="arrow">›</text>
    </view>

    <view class="menu-item muted">
      <text>存储方式</text>
      <text>{{cloudAvailable ? '本机缓存 + 腾讯云云数据库' : '本机小程序缓存'}}</text>
    </view>
  </view>
</view>
