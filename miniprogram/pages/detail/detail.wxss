.loading,
.notice {
  margin-bottom: 16rpx;
  color: #7d8996;
}

.notice {
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  color: #8a5a00;
  background: #fff6db;
  border: 1rpx solid #f4df9f;
}

.detail {
  padding: 26rpx;
}

.fund-head,
.update-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.fund-name {
  max-width: 490rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #1f2730;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fund-code {
  margin-top: 8rpx;
  color: #8793a0;
  font-size: 24rpx;
}

.fund-rate {
  font-size: 38rpx;
  font-weight: 800;
}

.metrics,
.rank-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx 26rpx;
  margin-top: 30rpx;
}

.rank-grid {
  margin-top: 0;
  padding: 22rpx;
}

.rank-item {
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 8rpx;
}

.rank-rate {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
}

.rank-text {
  display: block;
  margin-top: 6rpx;
  color: #8793a0;
  font-size: 23rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 23rpx;
  color: #7d8996;
}

.quote-status {
  margin-top: 22rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  color: #8a5a00;
  background: #fff6db;
  font-size: 23rpx;
}

.update-row {
  margin-top: 24rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f6;
  color: #8793a0;
  font-size: 23rpx;
}

.info {
  overflow: hidden;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  flex: 0 0 150rpx;
  color: #7d8996;
}

.info-value {
  flex: 1;
  text-align: right;
  color: #1f2730;
}

.history {
  overflow: hidden;
}

.history-row {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr 1fr;
  gap: 12rpx;
  padding: 20rpx 18rpx;
  border-bottom: 1rpx solid #edf1f5;
  font-size: 25rpx;
}

.history-row:last-child {
  border-bottom: 0;
}

.history-head {
  color: #7d8996;
  background: #f8fafc;
  font-size: 23rpx;
}
.record-button {
  min-width: 120rpx;
}

.history-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rpx;
  border-top: 1rpx solid #e5ebf2;
  border-bottom: 1rpx solid #e5ebf2;
  background: #e5ebf2;
}

.history-summary view {
  padding: 20rpx 12rpx;
  text-align: center;
  background: #ffffff;
}

.history-summary text,
.summary-strong {
  display: block;
}

.history-summary text {
  color: #7d8996;
  font-size: 22rpx;
}

.history-summary .summary-strong {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.profit-chart-wrap {
  margin-top: 18rpx;
  padding: 18rpx;
  border-top: 1rpx solid #e5ebf2;
  border-bottom: 1rpx solid #e5ebf2;
  background: #ffffff;
}

.profit-chart {
  width: 100%;
  height: 300rpx;
}

.chart-axis {
  display: flex;
  justify-content: space-between;
  color: #8793a0;
  font-size: 21rpx;
}

.calculation-table {
  margin-top: 18rpx;
  overflow: hidden;
  border-top: 1rpx solid #e5ebf2;
  border-bottom: 1rpx solid #e5ebf2;
  background: #ffffff;
}

.calculation-scroll {
  height: 560rpx;
}

.calculation-row {
  display: grid;
  grid-template-columns: 1.2fr 0.9fr 1.1fr 1.1fr;
  gap: 10rpx;
  align-items: center;
  min-height: 76rpx;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #edf1f5;
  font-size: 22rpx;
}

.calculation-head {
  min-height: 68rpx;
  color: #7d8996;
  background: #f8fafc;
}

.row-rate {
  display: block;
  margin-top: 3rpx;
  font-size: 20rpx;
}
.history-summary .summary-strong.up {
  color: #d64242;
}

.history-summary .summary-strong.down {
  color: #12834f;
}

.estimate-tag {
  display: inline-block;
  margin-left: 6rpx;
  padding: 0 6rpx;
  border-radius: 6rpx;
  color: #276ef1;
  background: #eef4ff;
  font-size: 18rpx;
  line-height: 26rpx;
}
.section-meta {
  font-size: 22rpx;
  font-weight: 400;
  color: #8793a0;
}

.position {
  overflow: hidden;
}

.position-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 22rpx;
  color: #7d8996;
  background: #f8fafc;
  border-bottom: 1rpx solid #edf1f5;
  font-size: 24rpx;
}

.position-total {
  color: #1f2730;
  font-size: 30rpx;
  font-weight: 800;
}

.position-empty {
  padding: 46rpx 24rpx;
}

.position-row {
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.position-row:last-child {
  border-bottom: 0;
}

.position-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.position-rank {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 8rpx;
  color: #276ef1;
  background: #eef4ff;
  font-size: 22rpx;
  font-weight: 800;
}

.position-name-box {
  min-width: 0;
  flex: 1;
}

.position-name {
  display: block;
  color: #1f2730;
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.position-code {
  display: block;
  margin-top: 4rpx;
  color: #8793a0;
  font-size: 22rpx;
}

.position-ratio-box {
  margin-top: 16rpx;
}

.position-ratio-line,
.position-market {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.position-ratio-line {
  color: #7d8996;
  font-size: 23rpx;
}

.position-ratio {
  color: #1f2730;
  font-weight: 800;
}

.position-bar {
  height: 10rpx;
  margin-top: 10rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #eef2f6;
}

.position-bar-inner {
  height: 100%;
  max-width: 100%;
  border-radius: 8rpx;
  background: #276ef1;
}

.position-market {
  margin-top: 12rpx;
  color: #8793a0;
  font-size: 22rpx;
}

.position-note {
  margin-top: 12rpx;
  color: #8793a0;
  font-size: 22rpx;
  line-height: 1.5;
}